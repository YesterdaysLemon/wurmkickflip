{
  "name": "wurmkickflip",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=22.13 <23"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build && npm run verify:bundle",
    "typecheck": "npm run typecheck:app && npm run typecheck:verifiers",
    "typecheck:app": "tsc -p tsconfig.json",
    "typecheck:verifiers": "tsc -p tsconfig.verifiers.json",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "python:lint": "cd training && uv run --group dev ruff check wurmkickflip_rl",
    "python:typecheck": "cd training && uv run --group dev pyright",
    "python:check": "npm run python:lint && npm run python:typecheck",
    "verify:configs": "tsx scripts/verify-configs.ts",
    "verify:bundle": "tsx scripts/verify-bundle-budget.ts",
    "verify:contract": "node scripts/verify-policy-contract.mjs",
    "verify:env": "tsx scripts/verify-env-metrics.ts",
    "verify:evolution": "tsx scripts/verify-evolution.ts",
    "verify:parity": "tsx scripts/verify-observation-parity.ts",
    "verify:replay": "tsx scripts/verify-replay-schema.ts",
    "verify:runtime": "tsx scripts/verify-policy-runtime.ts",
    "verify:stunt-policy": "tsx scripts/verify-stunt-policy.ts",
    "verify:terrain": "tsx scripts/verify-terrain-field.ts",
    "verify:simulation": "tsx scripts/verify-terrarium-simulation.ts",
    "verify:collisions": "tsx scripts/verify-terrarium-collisions.ts",
    "verify:dynamics": "tsx scripts/verify-worm-dynamics.ts",
    "verify:performance": "tsx scripts/verify-simulation-performance.ts",
    "verify:interactions": "tsx scripts/verify-worm-interaction-animation.ts",
    "verify:needs": "tsx scripts/verify-terrarium-needs.ts",
    "verify:locomotion": "tsx scripts/verify-locomotion-policy.ts",
    "verify:locomotion:published": "tsx scripts/verify-published-locomotion.ts",
    "verify:motion": "tsx scripts/verify-stunt-motion.ts",
    "verify:fast": "npm run verify:configs && npm run verify:terrain && npm run verify:simulation && npm run verify:collisions && npm run verify:dynamics && npm run verify:interactions && npm run verify:needs && npm run verify:contract && npm run verify:replay",
    "verify:integration": "npm run verify:locomotion && npm run verify:parity && npm run verify:stunt-policy && npm run verify:motion && npm run verify:runtime && npm run verify:env && npm run verify:evolution && npm run verify:performance",
    "check:static": "npm run typecheck && npm run lint && npm run format:check && npm run python:check",
    "check:fast": "npm run check:static && npm run verify:fast && npm run build",
    "check:integration": "npm run verify:integration",
    "check:repro": "npm run verify:locomotion:published",
    "check:browser": "playwright test",
    "check": "npm run check:fast && npm run check:integration",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0"
  }
}
